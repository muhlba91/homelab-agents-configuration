{
  "version": 2,
  "agents": {
    "defaults": {
      "workspace": "/root/.picoclaw/workspace",
      "restrict_to_workspace": true,
      "model_name": "gemini-flash-lite",
      "max_tokens": 8192,
      "max_tool_iterations": 10,
      "summarize_token_percent": 40,
      "summarize_message_threshold": 8
    }
  },
  "model_list": [
    {
      "model_name": "qwen",
      "model": "litellm/qwen3.5",
      "enabled": true,
      "api_base": "http://litellm.litellm:4000/v1",
      "api_keys": [
        "${LITELLM_API_KEY}"
      ]
    },
    {
      "model_name": "gemma",
      "model": "litellm/gemma4",
      "enabled": true,
      "api_base": "http://litellm.litellm:4000/v1",
      "api_keys": [
        "${LITELLM_API_KEY}"
      ]
    },
    {
      "model_name": "gemini-flash-lite",
      "model": "litellm/gemini-3.1-flash-lite-preview",
      "enabled": true,
      "api_base": "http://litellm.litellm:4000/v1",
      "api_keys": [
        "${LITELLM_API_KEY}"
      ]
    }
  ],
  "channels": {
    "discord": {
      "enabled": true,
      "allow_from": [
        "700068305230364768"
      ],
      "group_trigger": {
        "mention_only": false
      }
    }
  },
  "tools": {
    "web": {
      "duckduckgo": {
        "enabled": true,
        "max_results": 3
      }
    },
    "exec": {
      "enabled": true,
      "enable_deny_patterns": true,
      "custom_allow_patterns": [
        "^picoclaw .*$"
      ]
    },
    "skills": {
      "registries": {
        "clawhub": {
          "enabled": false
        }
      }
    },
    "cron": {
      "enabled": true,
      "exec_timeout_minutes": 5
    },
    "mcp": {
      "enabled": true,
      "discovery": {
        "enabled": true,
        "max_search_results": 5,
        "ttl": 10,
        "use_bm25": true
      },
      "servers": {
        "kubernetes": {
          "enabled": true,
          "type": "http",
          "url": "http://agents-mcp-server-kubernetes:8080/mcp"
        },
        "github": {
          "enabled": true,
          "type": "sse",
          "url": "https://api.githubcopilot.com/mcp",
          "headers": {
            "X-MCP-Toolsets": "context,actions,issues,labels,notifications,pull_requests,repos",
            "Authorization": "Bearer ${GITHUB_MCP_TOKEN}"
          }
        },
        "metrics": {
          "enabled": true,
          "type": "http",
          "url": "http://agents-mcp-server-victoria-metrics:8080/mcp"
        },
        "logs": {
          "enabled": true,
          "type": "http",
          "url": "http://agents-mcp-server-victoria-logs:8080/mcp"
        }
      }
    }
  },
  "heartbeat": {
    "enabled": true,
    "interval": 60
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790,
    "log_level": "info",
    "hot_reload": true
  }
}